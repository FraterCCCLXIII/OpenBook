# Copy to apps/api/.env and apps/web/.env as needed

# API (apps/api)
PORT=3002
CORS_ORIGIN=http://localhost:5173
APP_VERSION=0.0.1

# Database (Prisma — wire in Phase 1)
# DATABASE_URL=mysql://openbook:openbook@127.0.0.1:3306/openbook

# Redis (BullMQ — wire in integrations phase; docker-compose maps 6380→6379)
# REDIS_URL=redis://127.0.0.1:6380

# SMTP (Mailpit from docker-compose; UI http://localhost:8027)
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1027
