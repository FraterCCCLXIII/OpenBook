# Copy to `.env` in this directory. For local dev, generate secrets (see below).

DATABASE_URL="mysql://openbook:openbook@127.0.0.1:3306/openbook"

# Generate for local development (do not commit real production values):
#   openssl rand -hex 32
JWT_SECRET=""

# Optional: for GET /api/v1/* with Bearer token (openssl rand -hex 24)
OPENBOOK_API_TOKEN=""

# Optional
# PORT=3002
# REDIS_URL=redis://127.0.0.1:6380
# SMTP_PORT=1027
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Cloudflare Turnstile (when Booking → Require CAPTCHA is enabled)
# Site key is safe to expose; merged into GET /api/settings/public as `turnstile_site_key`.
# OPENBOOK_TURNSTILE_SITE_KEY=
# Secret key: server-side verification only (never expose to the browser).
# OPENBOOK_TURNSTILE_SECRET_KEY=
