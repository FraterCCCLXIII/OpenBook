# Copy to `.env` in this directory. For local dev, generate secrets (see below).

DATABASE_URL="mysql://openbook:openbook@127.0.0.1:3306/openbook"

# Generate for local development (do not commit real production values):
#   openssl rand -hex 32
JWT_SECRET=""

# Optional: for GET /api/v1/* with Bearer token (openssl rand -hex 24)
OPENBOOK_API_TOKEN=""

