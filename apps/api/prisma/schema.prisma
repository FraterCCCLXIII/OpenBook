// Easy!Appointments MySQL tables (prefix ea_). Run `pnpm prisma generate` in apps/api.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id               BigInt @id @default(autoincrement())
  name             String? @db.VarChar(256)
  slug             String? @db.VarChar(256)
  isAdmin          Int?    @map("is_admin") @db.TinyInt
  appointments     Int?
  customers        Int?
  services         Int?
  usersPerm        Int?    @map("users")
  systemSettings   Int?    @map("system_settings")
  userSettings     Int?    @map("user_settings")
  webhooks         Int?
  blockedPeriods   Int?    @map("blocked_periods")

  staffUsers User[]

  @@map("ea_roles")
}

model User {
  id          BigInt  @id @default(autoincrement())
  firstName   String? @map("first_name") @db.VarChar(256)
  lastName    String? @map("last_name") @db.VarChar(512)
  email       String? @db.VarChar(512)
  idRoles     BigInt  @map("id_roles")
  timezone    String? @db.VarChar(512)
  language    String? @db.VarChar(512)
  phoneNumber String? @map("phone_number") @db.VarChar(128)
  address     String? @db.VarChar(256)
  city        String? @db.VarChar(256)
  state       String? @db.VarChar(128)
  zipCode     String? @map("zip_code") @db.VarChar(64)

  role         Role           @relation(fields: [idRoles], references: [id])
  userSettings UserSettings?
  customerAuth CustomerAuth?

  providerAppointments Appointment[] @relation("ApptProvider")
  customerAppointments Appointment[] @relation("ApptCustomer")
  serviceLinks         ServiceProvider[]
  formSubmissions      FormSubmission[]
  customerNotes        CustomerNote[]
  customerAlerts       CustomerAlert[]
  customFieldValues    CustomerCustomFieldValue[]
  userFiles            UserFile[]
  consents             Consent[]

  @@map("ea_users")
}

model UserSettings {
  idUsers BigInt @id @map("id_users")

  username               String? @db.VarChar(256)
  password               String? @db.VarChar(512)
  salt                   String? @db.VarChar(512)
  workingPlan            String? @map("working_plan") @db.Text
  workingPlanExceptions  String? @map("working_plan_exceptions") @db.Text
  notifications          Int?    @db.TinyInt
  googleSync             Int?    @map("google_sync") @db.TinyInt
  googleToken            String? @map("google_token") @db.Text
  googleCalendar         String? @map("google_calendar") @db.VarChar(128)
  syncPastDays           Int?    @map("sync_past_days")
  syncFutureDays         Int?    @map("sync_future_days")

  user User @relation(fields: [idUsers], references: [id], onDelete: Cascade)

  @@map("ea_user_settings")
}

model CustomerAuth {
  id           Int     @id @default(autoincrement())
  customerId   BigInt  @unique @map("customer_id")
  email        String  @db.VarChar(512)
  passwordHash String? @map("password_hash") @db.VarChar(255)
  status       String  @default("active") @db.VarChar(32)

  user User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("ea_customer_auth")
}

model Setting {
  id    BigInt  @id @default(autoincrement())
  name  String? @db.VarChar(512)
  value String? @db.LongText

  @@map("ea_settings")
}

model ServiceCategory {
  id          BigInt  @id @default(autoincrement())
  name        String? @db.VarChar(256)
  description String? @db.Text

  services Service[]

  @@map("ea_service_categories")
}

model Service {
  id                   BigInt  @id @default(autoincrement())
  name                 String? @db.VarChar(256)
  duration             Int?
  price                Decimal? @db.Decimal(10, 2)
  currency             String? @db.VarChar(32)
  description          String? @db.Text
  idServiceCategories  BigInt? @map("id_service_categories")
  availabilitiesType   String? @map("availabilities_type") @db.VarChar(32)
  attendantsNumber     Int?    @default(1) @map("attendants_number")
  isPrivate            Int?    @default(0) @map("is_private") @db.TinyInt

  category ServiceCategory? @relation(fields: [idServiceCategories], references: [id], onDelete: SetNull)
  providers ServiceProvider[]
  appointments Appointment[]

  @@map("ea_services")
}

model ServiceProvider {
  idUsers    BigInt @map("id_users")
  idServices BigInt @map("id_services")

  user    User    @relation(fields: [idUsers], references: [id], onDelete: Cascade)
  service Service @relation(fields: [idServices], references: [id], onDelete: Cascade)

  @@id([idUsers, idServices])
  @@map("ea_services_providers")
}

model Appointment {
  id                 BigInt    @id @default(autoincrement())
  bookDatetime       DateTime? @map("book_datetime") @db.DateTime(0)
  startDatetime      DateTime? @map("start_datetime") @db.DateTime(0)
  endDatetime        DateTime? @map("end_datetime") @db.DateTime(0)
  notes              String?   @db.Text
  hash               String?   @db.Text
  isUnavailability   Int       @default(0) @map("is_unavailability") @db.TinyInt
  idUsersProvider    BigInt?   @map("id_users_provider")
  idUsersCustomer    BigInt?   @map("id_users_customer")
  idServices         BigInt?   @map("id_services")

  provider User?   @relation("ApptProvider", fields: [idUsersProvider], references: [id], onDelete: Cascade)
  customer User?   @relation("ApptCustomer", fields: [idUsersCustomer], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [idServices], references: [id], onDelete: Cascade)
  payments         AppointmentPayment[]
  appointmentNotes AppointmentNote[]

  @@index([idUsersProvider])
  @@index([startDatetime])
  @@map("ea_appointments")
}

model BlockedPeriod {
  id              Int       @id @default(autoincrement())
  createDatetime  DateTime? @map("create_datetime") @db.DateTime(0)
  updateDatetime  DateTime? @map("update_datetime") @db.DateTime(0)
  name            String?   @db.VarChar(256)
  startDatetime   DateTime? @map("start_datetime") @db.DateTime(0)
  endDatetime     DateTime? @map("end_datetime") @db.DateTime(0)
  notes           String?   @db.Text

  @@map("ea_blocked_periods")
}

model CustomerOtp {
  id                     Int       @id @default(autoincrement())
  email                  String    @db.VarChar(512)
  emailHash              String?   @map("email_hash") @db.VarChar(512)
  codeHash               String?   @map("code_hash") @db.VarChar(512)
  expiresAt              DateTime? @map("expires_at") @db.DateTime(0)
  attemptCount           Int       @default(0) @map("attempt_count")
  attemptWindowStartedAt DateTime? @map("attempt_window_started_at") @db.DateTime(0)
  sendCount              Int       @default(0) @map("send_count")
  sendWindowStartedAt    DateTime? @map("send_window_started_at") @db.DateTime(0)
  lastSendAt             DateTime? @map("last_send_at") @db.DateTime(0)
  lastAttemptAt          DateTime? @map("last_attempt_at") @db.DateTime(0)
  lockoutUntil           DateTime? @map("lockout_until") @db.DateTime(0)
  createDatetime         DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime         DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  @@index([email])
  @@map("ea_customer_otp")
}

model Form {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(256)
  slug           String    @unique @db.VarChar(256)
  description    String?   @db.Text
  isActive       Int       @default(1) @map("is_active") @db.TinyInt
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  fields      FormField[]
  submissions FormSubmission[]
  assignments FormAssignment[]

  @@map("ea_forms")
}

model FormField {
  id             Int     @id @default(autoincrement())
  idForms        Int     @map("id_forms")
  label          String  @db.VarChar(256)
  fieldType      String  @default("input") @map("field_type") @db.VarChar(32)
  options        String? @db.Text
  isRequired     Int     @default(0) @map("is_required") @db.TinyInt
  isActive       Int     @default(1) @map("is_active") @db.TinyInt
  sortOrder      Int     @default(0) @map("sort_order")

  form Form @relation(fields: [idForms], references: [id], onDelete: Cascade)

  @@index([idForms])
  @@map("ea_form_fields")
}

model FormSubmission {
  id             Int       @id @default(autoincrement())
  idForms        Int       @map("id_forms")
  idUsers        BigInt    @map("id_users")
  submittedAt    DateTime? @default(now()) @map("submitted_at") @db.DateTime(0)
  fieldsSnapshot String?   @map("fields_snapshot") @db.LongText

  form Form @relation(fields: [idForms], references: [id], onDelete: Cascade)
  user User @relation(fields: [idUsers], references: [id], onDelete: Cascade)

  @@index([idForms])
  @@index([idUsers])
  @@map("ea_form_submissions")
}

model FormAssignment {
  id       Int    @id @default(autoincrement())
  idForms  Int    @map("id_forms")
  roleSlug String @map("role_slug") @db.VarChar(64)

  form Form @relation(fields: [idForms], references: [id], onDelete: Cascade)

  @@index([idForms])
  @@map("ea_form_assignments")
}

model Webhook {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(256)
  url            String    @db.VarChar(1024)
  actions        String?   @db.VarChar(512)
  secretToken    String?   @map("secret_token") @db.VarChar(256)
  isActive       Int       @default(1) @map("is_active") @db.TinyInt
  isSslVerified  Int       @default(1) @map("is_ssl_verified") @db.TinyInt
  notes          String?   @db.Text
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  @@map("ea_webhooks")
}

model AppointmentPayment {
  id                     Int       @id @default(autoincrement())
  idAppointments         BigInt    @map("id_appointments")
  amount                 Decimal?  @db.Decimal(10, 2)
  currency               String?   @db.VarChar(8)
  status                 String    @default("pending") @db.VarChar(32)
  stripeEventId          String?   @map("stripe_event_id") @db.VarChar(255)
  stripePaymentIntentId  String?   @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeCheckoutSessionId String?  @map("stripe_checkout_session_id") @db.VarChar(255)
  createDatetime         DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime         DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  appointment Appointment @relation(fields: [idAppointments], references: [id], onDelete: Cascade)

  @@index([idAppointments])
  @@index([stripeEventId])
  @@index([stripePaymentIntentId])
  @@map("ea_appointment_payments")
}

model Consent {
  id             Int       @id @default(autoincrement())
  ip             String    @db.VarChar(64)
  type           String    @db.VarChar(64)
  idUsers        BigInt?   @map("id_users")
  firstName      String?   @map("first_name") @db.VarChar(256)
  lastName       String?   @map("last_name") @db.VarChar(256)
  email          String?   @db.VarChar(512)
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  user User? @relation(fields: [idUsers], references: [id], onDelete: SetNull)

  @@index([idUsers])
  @@map("ea_consents")
}

// OpenBook-native audit trail (not from legacy PHP ea_*).
model AuditLog {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  action    String?  @db.VarChar(512)
  metadata  String?  @db.Text

  @@map("openbook_audit_logs")
}

/// Stripe webhook idempotency (event id is unique per delivery).
model StripeWebhookEvent {
  id         String   @id @db.VarChar(255)
  eventType  String?  @map("event_type") @db.VarChar(128)
  receivedAt DateTime @default(now()) @map("received_at") @db.DateTime(0)

  @@map("openbook_stripe_events")
}

// ─── Additional PHP-fork models ──────────────────────────────────────────────

model GeoNamesPostalCode {
  id          BigInt  @id @default(autoincrement())
  postalCode  String  @map("postal_code") @db.VarChar(20)
  countryCode String  @map("country_code") @db.VarChar(2)
  placeName   String? @map("place_name") @db.VarChar(256)
  adminName1  String? @map("admin_name1") @db.VarChar(256)
  adminCode1  String? @map("admin_code1") @db.VarChar(20)
  latitude    Float?
  longitude   Float?

  @@index([postalCode, countryCode])
  @@map("ea_geonames_postal_codes")
}

model AppointmentNote {
  id             BigInt    @id @default(autoincrement())
  idAppointments BigInt    @map("id_appointments")
  idUsersAuthor  BigInt?   @map("id_users_author")
  note           String?   @db.Text
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  appointment Appointment @relation(fields: [idAppointments], references: [id], onDelete: Cascade)

  @@index([idAppointments])
  @@map("ea_appointment_notes")
}

model CustomerNote {
  id             BigInt    @id @default(autoincrement())
  idUsers        BigInt    @map("id_users")
  notes          String?   @db.Text
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  user User @relation(fields: [idUsers], references: [id], onDelete: Cascade)

  @@index([idUsers])
  @@map("ea_customer_notes")
}

model CustomerAlert {
  id             BigInt    @id @default(autoincrement())
  idUsers        BigInt    @map("id_users")
  message        String?   @db.Text
  isRead         Int       @default(0) @map("is_read") @db.TinyInt
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)

  user User @relation(fields: [idUsers], references: [id], onDelete: Cascade)

  @@index([idUsers])
  @@map("ea_customer_alerts")
}

model CustomField {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(256)
  fieldType      String    @default("input") @map("field_type") @db.VarChar(32)
  defaultValue   String?   @map("default_value") @db.Text
  isRequired     Int       @default(0) @map("is_required") @db.TinyInt
  isDisplayed    Int       @default(1) @map("is_displayed") @db.TinyInt
  isActive       Int       @default(1) @map("is_active") @db.TinyInt
  sortOrder      Int       @default(0) @map("sort_order")
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  values CustomerCustomFieldValue[]

  @@map("ea_custom_fields")
}

model CustomerCustomFieldValue {
  id             BigInt    @id @default(autoincrement())
  idUsers        BigInt    @map("id_users")
  idCustomFields Int       @map("id_custom_fields")
  value          String?   @db.Text
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)
  updateDatetime DateTime? @updatedAt @map("update_datetime") @db.DateTime(0)

  user        User        @relation(fields: [idUsers], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [idCustomFields], references: [id], onDelete: Cascade)

  @@index([idUsers])
  @@index([idCustomFields])
  @@map("ea_customer_custom_field_values")
}

model UserFile {
  id           BigInt    @id @default(autoincrement())
  idUsers      BigInt    @map("id_users")
  filename     String    @db.VarChar(512)
  originalName String    @map("original_name") @db.VarChar(512)
  mimeType     String    @map("mime_type") @db.VarChar(128)
  sizeBytes    Int       @map("file_size") @default(0)
  createDatetime DateTime? @default(now()) @map("create_datetime") @db.DateTime(0)

  user User @relation(fields: [idUsers], references: [id], onDelete: Cascade)

  @@index([idUsers])
  @@map("ea_user_files")
}
